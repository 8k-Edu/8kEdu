[
 {
  "start": 0.21,
  "end": 2.97,
  "text": "chef and culinary instructor"
 },
 {
  "start": 2.97,
  "end": 3.96,
  "text": "and today I'm gonna show you"
 },
 {
  "start": 3.96,
  "end": 8.22,
  "text": "how to make scrambled eggs, Frank style."
 },
 {
  "start": 9.3,
  "end": 13.08,
  "text": "silky, creamy, scrambled eggs"
 },
 {
  "start": 13.08,
  "end": 15.09,
  "text": "not the dried, burnt kind."
 },
 {
  "start": 15.09,
  "end": 17.34,
  "text": "This is scrambled eggs 101."
 },
 {
  "start": 18.57,
  "end": 22.32,
  "text": "creamy and silky, not fluffy."
 },
 {
  "start": 22.32,
  "end": 23.58,
  "text": "I don't like fluffy eggs."
 },
 {
  "start": 23.58,
  "end": 26.94,
  "text": "scrambled eggs is butter,"
 },
 {
  "start": 26.94,
  "end": 29.7,
  "text": "timing, and a little bit of love."
 },
 {
  "start": 29.7,
  "end": 31.98,
  "text": "[upbeat music]"
 },
 {
  "start": 31.98,
  "end": 33.33,
  "text": "I like to take my eggs out"
 },
 {
  "start": 33.33,
  "end": 37.14,
  "text": "minutes before I cook them."
 },
 {
  "start": 37.14,
  "end": 39.96,
  "text": "Not only do they whisk better together,"
 },
 {
  "start": 39.96,
  "end": 41.76,
  "text": "they also cook a little quicker."
 },
 {
  "start": 41.76,
  "end": 43.23,
  "text": "I have three eggs in the bowl."
 },
 {
  "start": 43.23,
  "end": 44.58,
  "text": "I'm gonna whisk my eggs with a fork."
 },
 {
  "start": 44.58,
  "end": 46.83,
  "text": "much air into the eggs."
 },
 {
  "start": 46.83,
  "end": 49.62,
  "text": "and silky and not fluffy."
 },
 {
  "start": 49.62,
  "end": 50.67,
  "text": "I like to beat my eggs"
 },
 {
  "start": 50.67,
  "end": 52.74,
  "text": "combined and then I stop."
 },
 {
  "start": 52.74,
  "end": 54.24,
  "text": "No extra air in there."
 },
 {
  "start": 54.24,
  "end": 55.11,
  "text": "Yeah, and that's it."
 },
 {
  "start": 55.11,
  "end": 56.61,
  "text": "My eggs are mixed really nice."
 },
 {
  "start": 59.13,
  "end": 61.08,
  "text": "under a minute to cook"
 },
 {
  "start": 61.08,
  "end": 63.27,
  "text": "to have everything you need"
 },
 {
  "start": 63.27,
  "end": 64.15,
  "text": "laid out in front of you."
 },
 {
  "start": 64.15,
  "end": 66.18,
  "text": "I have my butter, I have my seasoning."
 },
 {
  "start": 66.18,
  "end": 68.28,
  "text": "I have a towel in case I burn my hands"
 },
 {
  "start": 68.28,
  "end": 69.81,
  "text": "and I have my eggs ready to go."
 },
 {
  "start": 69.81,
  "end": 73.02,
  "text": "and I'm using a non-stick pan."
 },
 {
  "start": 73.02,
  "end": 75.42,
  "text": "if you don't preheat this"
 },
 {
  "start": 75.42,
  "end": 77.19,
  "text": "the eggs tend to stick."
 },
 {
  "start": 77.19,
  "end": 78.6,
  "text": "I like to preheat my pan,"
 },
 {
  "start": 78.6,
  "end": 81.57,
  "text": "there, and then cook my eggs."
 },
 {
  "start": 81.57,
  "end": 83.82,
  "text": "So my pan is nice and hot."
 },
 {
  "start": 83.82,
  "end": 85.2,
  "text": "It's over medium heat."
 },
 {
  "start": 85.2,
  "end": 87.9,
  "text": "amount of unsalted butter."
 },
 {
  "start": 87.9,
  "end": 89.46,
  "text": "The butter gives our eggs flavor"
 },
 {
  "start": 89.46,
  "end": 91.92,
  "text": "much salt goes into them."
 },
 {
  "start": 91.92,
  "end": 95.13,
  "text": "a vegetable oil, that's fine"
 },
 {
  "start": 95.13,
  "end": 96.39,
  "text": "but there's no flavor in that."
 },
 {
  "start": 96.39,
  "end": 97.65,
  "text": "So to start to scramble"
 },
 {
  "start": 97.65,
  "end": 100.08,
  "text": "knob of butter to my pan."
 },
 {
  "start": 100.08,
  "end": 101.73,
  "text": "butter is fully melted"
 },
 {
  "start": 101.73,
  "end": 103.17,
  "text": "I just want it to coat the bottom"
 },
 {
  "start": 103.17,
  "end": 105.48,
  "text": "of the pan before I put my eggs in."
 },
 {
  "start": 105.48,
  "end": 107.29,
  "text": "Now's when I want to add my eggs"
 },
 {
  "start": 108.93,
  "end": 110.79,
  "text": "little bit of salt now,"
 },
 {
  "start": 110.79,
  "end": 114.36,
  "text": "my eggs are still liquid."
 },
 {
  "start": 114.36,
  "end": 116.55,
  "text": "This way the salt melts into the eggs"
 },
 {
  "start": 116.55,
  "end": 118.29,
  "text": "just gonna bring them"
 },
 {
  "start": 118.29,
  "end": 121.17,
  "text": "of like move them around."
 },
 {
  "start": 121.17,
  "end": 123.18,
  "text": "You have a few choices at this point."
 },
 {
  "start": 123.18,
  "end": 126.39,
  "text": "curds or small curds,"
 },
 {
  "start": 126.39,
  "end": 127.38,
  "text": "It's totally up to you"
 },
 {
  "start": 127.38,
  "end": 130.8,
  "text": "little on the larger side."
 },
 {
  "start": 130.8,
  "end": 132.32,
  "text": "I usually stop cooking"
 },
 {
  "start": 132.32,
  "end": 135.18,
  "text": "once my eggs are no longer liquidy, right?"
 },
 {
  "start": 135.18,
  "end": 137.19,
  "text": "I don't want these to be liquidy and wet."
 },
 {
  "start": 137.19,
  "end": 140.49,
  "text": "slightly creamy and shiny."
 },
 {
  "start": 140.49,
  "end": 142.2,
  "text": "Eggs do carry over cook."
 },
 {
  "start": 142.2,
  "end": 144.42,
  "text": "take them out of the pan,"
 },
 {
  "start": 144.42,
  "end": 146.04,
  "text": "they're done, they're done."
 },
 {
  "start": 148.98,
  "end": 150.57,
  "text": "Let's get 'em on a plate."
 },
 {
  "start": 150.57,
  "end": 152.58,
  "text": "might disagree with me"
 },
 {
  "start": 152.58,
  "end": 155.07,
  "text": "bit of black pepper,"
 },
 {
  "start": 155.07,
  "end": 156.75,
  "text": "just a little, just for flavor."
 },
 {
  "start": 156.75,
  "end": 158.16,
  "text": "You don't have to go too crazy."
 },
 {
  "start": 158.16,
  "end": 160.08,
  "text": "And then I take a little knob of butter"
 },
 {
  "start": 160.08,
  "end": 162.27,
  "text": "a little butter around"
 },
 {
  "start": 162.27,
  "end": 165.0,
  "text": "and let the butter melt into those eggs."
 },
 {
  "start": 165.0,
  "end": 166.86,
  "text": "make these scrambled eggs"
 },
 {
  "start": 166.86,
  "end": 169.77,
  "text": "are, and it tastes great."
 },
 {
  "start": 169.77,
  "end": 172.8,
  "text": "plate of scrambled eggs."
 },
 {
  "start": 172.8,
  "end": 173.85,
  "text": "Delicious scrambled eggs"
 },
 {
  "start": 173.85,
  "end": 175.48,
  "text": "sounds like something that's super easy,"
 },
 {
  "start": 175.48,
  "end": 177.45,
  "text": "but it can go horribly wrong."
 },
 {
  "start": 177.45,
  "end": 179.4,
  "text": "that overcooked, look at it."
 },
 {
  "start": 179.4,
  "end": 180.57,
  "text": "Come on, there's no choice."
 },
 {
  "start": 180.57,
  "end": 184.5,
  "text": "Look at my eggs, shiny, silky, delicious."
 },
 {
  "start": 184.5,
  "end": 187.02,
  "text": "Look at these, dry and sad."
 },
 {
  "start": 187.02,
  "end": 189.48,
  "text": "Creamy, delicious eggs,"
 },
 {
  "start": 189.48,
  "end": 193.32,
  "text": "dry bouncy little rubber balls on a plate."
 },
 {
  "start": 193.32,
  "end": 195.09,
  "text": "All right, it is time to taste."
 },
 {
  "start": 195.09,
  "end": 196.99,
  "text": "Let me get a little piece of egg here."
 },
 {
  "start": 197.94,
  "end": 200.04,
  "text": "get that nice creaminess"
 },
 {
  "start": 200.04,
  "end": 203.58,
  "text": "you get the egg flavor."
 },
 {
  "start": 203.58,
  "end": 205.59,
  "text": "to make scrambled eggs"
 },
 {
  "start": 205.59,
  "end": 206.42,
  "text": "and a little bit"
 },
 {
  "start": 206.42,
  "end": 208.47,
  "text": "of technique makes them extra decadent."
 },
 {
  "start": 208.47,
  "end": 210.3,
  "text": "Fluffy scrambled eggs are overrated."
 },
 {
  "start": 210.3,
  "end": 212.25,
  "text": "Try my buttery scrambled eggs"
 },
 {
  "start": 212.25,
  "end": 214.55,
  "text": "to fluffy eggs again."
 }
]