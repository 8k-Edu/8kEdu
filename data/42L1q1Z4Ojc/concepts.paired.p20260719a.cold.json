    "import numpy as np",
    "import matplotlib.pyplot as plt",
    "def linear_layer(x):",
    "    \"\"\"Apply a 512x512 linear transformation to the input.\"\"\"",
    "    W = np.random.randn(512, 512) * 0.01",
    "    b = np.zeros(512)",
    "    return x @ W + b",
    "x = np.random.randn(3, 512).reshape(-1, 512)  # Simulate concatenated 512-dim vector",
    "y = linear_layer(x)  # Apply the final linear layer",
    "plt.plot(y[0])  # Plot first dimension",
