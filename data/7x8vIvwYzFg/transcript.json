[
 {
  "start": 0.81,
  "end": 2.19,
  "text": "- [Presenter] Few things in the economy"
 },
 {
  "start": 2.19,
  "end": 5.02,
  "text": "are more closely watched than bond yields."
 },
 {
  "start": 5.02,
  "end": 7.42,
  "text": "play that merit watching."
 },
 {
  "start": 8.3,
  "end": 9.63,
  "text": "Some commodity prices"
 },
 {
  "start": 9.63,
  "end": 11.67,
  "text": "and 10-year treasury yields have climbed."
 },
 {
  "start": 11.67,
  "end": 12.78,
  "text": "- [Presenter] That's the president of"
 },
 {
  "start": 12.78,
  "end": 15.26,
  "text": "The Federal Reserve of Atlanta last March"
 },
 {
  "start": 15.26,
  "end": 18.23,
  "text": "Fed gauges inflation"
 },
 {
  "start": 18.23,
  "end": 22.02,
  "text": "eye on certain bond yields."
 },
 {
  "start": 22.02,
  "end": 25.37,
  "text": "a barometer for the economy,"
 },
 {
  "start": 25.37,
  "end": 27.39,
  "text": "but they're also more than that."
 },
 {
  "start": 27.39,
  "end": 30.06,
  "text": "are extremely important"
 },
 {
  "start": 30.06,
  "end": 32.6,
  "text": "to the US and even in the global economy."
 },
 {
  "start": 32.6,
  "end": 37.0,
  "text": "from the cost of a mortgage"
 },
 {
  "start": 37.0,
  "end": 39.77,
  "text": "to the cost of borrowing for businesses."
 },
 {
  "start": 39.77,
  "end": 41.67,
  "text": "If you're borrowing money,"
 },
 {
  "start": 41.67,
  "end": 43.68,
  "text": "to a large extent"
 },
 {
  "start": 43.68,
  "end": 46.03,
  "text": "by US government bond yields."
 },
 {
  "start": 46.03,
  "end": 48.68,
  "text": "in yields can impact you."
 },
 {
  "start": 48.68,
  "end": 50.3,
  "text": "Here's how bond yields work"
 },
 {
  "start": 50.3,
  "end": 52.9,
  "text": "and why they're so crucial to the economy."
 },
 {
  "start": 52.9,
  "end": 55.57,
  "text": "(bright music)"
 },
 {
  "start": 57.34,
  "end": 58.92,
  "text": "When we talk about a bond yield,"
 },
 {
  "start": 58.92,
  "end": 61.33,
  "text": "about the annualized return"
 },
 {
  "start": 61.33,
  "end": 65.05,
  "text": "bond until its maturity date."
 },
 {
  "start": 65.05,
  "end": 66.62,
  "text": "Let's break this down."
 },
 {
  "start": 66.62,
  "end": 69.05,
  "text": "features that are set"
 },
 {
  "start": 69.05,
  "end": 70.17,
  "text": "from the start."
 },
 {
  "start": 70.17,
  "end": 71.48,
  "text": "There's the maturity date,"
 },
 {
  "start": 71.48,
  "end": 73.92,
  "text": "length of the bond's life."
 },
 {
  "start": 73.92,
  "end": 76.36,
  "text": "This is generally two to 30 years."
 },
 {
  "start": 76.36,
  "end": 78.73,
  "text": "Bonds that mature between two and 10 years"
 },
 {
  "start": 78.73,
  "end": 80.53,
  "text": "are also called notes."
 },
 {
  "start": 80.53,
  "end": 83.02,
  "text": "value, which is the amount"
 },
 {
  "start": 83.02,
  "end": 85.26,
  "text": "the bond is worth when it's first created"
 },
 {
  "start": 85.26,
  "end": 88.56,
  "text": "to pay on the maturity date."
 },
 {
  "start": 88.56,
  "end": 90.62,
  "text": "There's also the annual interest rate,"
 },
 {
  "start": 90.62,
  "end": 92.75,
  "text": "otherwise known as the coupon rate."
 },
 {
  "start": 92.75,
  "end": 95.36,
  "text": "a bond pays each year"
 },
 {
  "start": 95.36,
  "end": 96.95,
  "text": "up to its maturity date."
 },
 {
  "start": 96.95,
  "end": 100.34,
  "text": "new 10-year treasury note"
 },
 {
  "start": 100.34,
  "end": 105.34,
  "text": "and a coupon or yield of 4%."
 },
 {
  "start": 105.83,
  "end": 109.25,
  "text": "Every year, the investor will receive $40"
 },
 {
  "start": 109.25,
  "end": 112.47,
  "text": "get back the original $1,000"
 },
 {
  "start": 112.47,
  "end": 114.15,
  "text": "she paid for the bond."
 },
 {
  "start": 114.15,
  "end": 117.39,
  "text": "soon as she buys that bond,"
 },
 {
  "start": 117.39,
  "end": 119.81,
  "text": "she can sell it to other investors"
 },
 {
  "start": 119.81,
  "end": 122.46,
  "text": "features of the bond"
 },
 {
  "start": 122.46,
  "end": 124.04,
  "text": "are subject to change."
 },
 {
  "start": 124.04,
  "end": 127.53,
  "text": "interest rates may go up,"
 },
 {
  "start": 127.53,
  "end": 130.37,
  "text": "be issued at a higher yield,"
 },
 {
  "start": 130.37,
  "end": 133.39,
  "text": "bringing down the value of existing bonds."
 },
 {
  "start": 133.39,
  "end": 137.69,
  "text": "treasuries pay a yield of 5%."
 },
 {
  "start": 137.69,
  "end": 141.22,
  "text": "attractive to investors"
 },
 {
  "start": 141.22,
  "end": 142.75,
  "text": "and the price has dropped."
 },
 {
  "start": 142.75,
  "end": 145.21,
  "text": "down, the yield goes up"
 },
 {
  "start": 145.21,
  "end": 146.94,
  "text": "and when interest rates go down,"
 },
 {
  "start": 146.94,
  "end": 149.47,
  "text": "this same dynamic happens in reverse."
 },
 {
  "start": 149.47,
  "end": 152.02,
  "text": "between the price of a bond"
 },
 {
  "start": 152.02,
  "end": 154.37,
  "text": "and it's yield is key to understanding"
 },
 {
  "start": 154.37,
  "end": 157.54,
  "text": "much about bond yields"
 },
 {
  "start": 157.54,
  "end": 160.26,
  "text": "see yields and stocks"
 },
 {
  "start": 160.26,
  "end": 162.66,
  "text": "both going up at the same time."
 },
 {
  "start": 162.66,
  "end": 164.1,
  "text": "- Investors generally like bonds"
 },
 {
  "start": 164.1,
  "end": 166.94,
  "text": "because they are a safe investment."
 },
 {
  "start": 166.94,
  "end": 169.92,
  "text": "return is gonna be often lower,"
 },
 {
  "start": 169.92,
  "end": 171.32,
  "text": "much lower than stocks."
 },
 {
  "start": 171.32,
  "end": 173.89,
  "text": "covers changes in bond yields"
 },
 {
  "start": 173.89,
  "end": 175.95,
  "text": "to financial markets"
 },
 {
  "start": 175.95,
  "end": 177.01,
  "text": "and the economy."
 },
 {
  "start": 177.01,
  "end": 179.62,
  "text": "confident about the economy,"
 },
 {
  "start": 179.62,
  "end": 182.59,
  "text": "with the small return"
 },
 {
  "start": 182.59,
  "end": 184.4,
  "text": "they can get from US government bonds."
 },
 {
  "start": 184.4,
  "end": 186.22,
  "text": "They might choose to buy stocks instead."
 },
 {
  "start": 186.22,
  "end": 189.01,
  "text": "treasury yields also signal"
 },
 {
  "start": 189.01,
  "end": 191.46,
  "text": "that borrowing is getting more expensive."
 },
 {
  "start": 191.46,
  "end": 195.77,
  "text": "longer-term interest rates."
 },
 {
  "start": 195.77,
  "end": 198.64,
  "text": "rough sense of, you know,"
 },
 {
  "start": 198.64,
  "end": 200.46,
  "text": "rates are gonna be going,"
 },
 {
  "start": 200.46,
  "end": 203.23,
  "text": "treasury note and it's yield."
 },
 {
  "start": 203.23,
  "end": 204.94,
  "text": "aren't just watched"
 },
 {
  "start": 204.94,
  "end": 206.65,
  "text": "by economists and investors."
 },
 {
  "start": 206.65,
  "end": 209.9,
  "text": "close eye on them as well."
 },
 {
  "start": 209.9,
  "end": 211.52,
  "text": "And they're not just watching."
 },
 {
  "start": 211.52,
  "end": 214.49,
  "text": "part of monetary policy"
 },
 {
  "start": 214.49,
  "end": 217.2,
  "text": "influence the economy."
 },
 {
  "start": 217.2,
  "end": 219.6,
  "text": "- There has been an underlying sense"
 },
 {
  "start": 219.6,
  "end": 222.66,
  "text": "and that has to be part of"
 },
 {
  "start": 222.66,
  "end": 224.92,
  "text": "why rates would move back up from"
 },
 {
  "start": 224.92,
  "end": 227.43,
  "text": "levels they were at."
 },
 {
  "start": 227.43,
  "end": 229.28,
  "text": "chairman of The Federal reserve"
 },
 {
  "start": 229.28,
  "end": 232.85,
  "text": "about the rise in bond yields"
 },
 {
  "start": 232.85,
  "end": 234.64,
  "text": "during the economic crisis."
 },
 {
  "start": 234.64,
  "end": 237.76,
  "text": "short-term interest rates"
 },
 {
  "start": 237.76,
  "end": 240.87,
  "text": "effort to bolster the economy"
 },
 {
  "start": 240.87,
  "end": 242.4,
  "text": "and encourage spending."
 },
 {
  "start": 242.4,
  "end": 244.95,
  "text": "are heavily influenced by"
 },
 {
  "start": 244.95,
  "end": 246.98,
  "text": "the outlook of short-term interest rates"
 },
 {
  "start": 246.98,
  "end": 249.3,
  "text": "also fell to record lows."
 },
 {
  "start": 249.3,
  "end": 252.52,
  "text": "the economy has rebounded."
 },
 {
  "start": 252.52,
  "end": 255.4,
  "text": "gained strength despite"
 },
 {
  "start": 255.4,
  "end": 258.94,
  "text": "rise to persistent supply"
 },
 {
  "start": 258.94,
  "end": 261.2,
  "text": "and demand imbalances and bottlenecks"
 },
 {
  "start": 261.2,
  "end": 263.12,
  "text": "and to elevated inflation."
 },
 {
  "start": 263.12,
  "end": 266.37,
  "text": "December inflation rose 7%"
 },
 {
  "start": 266.37,
  "end": 267.56,
  "text": "from a year earlier."
 },
 {
  "start": 267.56,
  "end": 270.05,
  "text": "The fastest pace since 1982."
 },
 {
  "start": 270.05,
  "end": 272.12,
  "text": "This reflected rapidly rising prices"
 },
 {
  "start": 272.12,
  "end": 274.87,
  "text": "on everything from houses to groceries."
 },
 {
  "start": 274.87,
  "end": 278.01,
  "text": "restrain an overheated economy,"
 },
 {
  "start": 278.01,
  "end": 280.42,
  "text": "it raises short-term interest rates."
 },
 {
  "start": 280.42,
  "end": 284.03,
  "text": "bond yields go up as well."
 },
 {
  "start": 284.03,
  "end": 286.66,
  "text": "- If inflation is uncomfortably high,"
 },
 {
  "start": 286.66,
  "end": 287.71,
  "text": "people don't like that."
 },
 {
  "start": 287.71,
  "end": 291.0,
  "text": "keeping prices stable"
 },
 {
  "start": 291.0,
  "end": 293.79,
  "text": "and so it'll try to cool the economy"
 },
 {
  "start": 293.79,
  "end": 296.53,
  "text": "by raising borrowing costs."
 },
 {
  "start": 296.53,
  "end": 298.36,
  "text": "interest rates can send up"
 },
 {
  "start": 298.36,
  "end": 300.34,
  "text": "the price of mortgages and other loans,"
 },
 {
  "start": 300.34,
  "end": 303.34,
  "text": "down consumer spending."
 },
 {
  "start": 303.34,
  "end": 306.31,
  "text": "thing, but only to a point."
 },
 {
  "start": 306.31,
  "end": 309.36,
  "text": "help cool down the economy,"
 },
 {
  "start": 309.36,
  "end": 312.27,
  "text": "inflation in the longterm."
 }
]