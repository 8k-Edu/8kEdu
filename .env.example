# 8kEdu environment — copy to `.env` and fill in. `.env` is gitignored (it holds secrets).

# ── LLM backends ─────────────────────────────────────────────────────────────
# Vision (widget extraction) backend used by run.sh and the agent batch jobs.
# One of: mlx | lmstudio | vllm | gemini | openai        (default: lmstudio)
# Keep this COMMENTED to leave the default in place and let a one-off command prefix work,
# e.g. `KEDU_BACKEND=vllm ./run.sh`. run.sh sources .env with `set -a`, so an uncommented
# value here would override that command-line prefix. Uncomment only to pin a backend for good.
# KEDU_BACKEND=lmstudio

# Shared by the lmstudio / openai / gemini backends — the active vision endpoint:
KEDU_BASE_URL=http://localhost:1234/v1
KEDU_MODEL=qwen/qwen3-vl-4b
# KEDU_API_KEY=none          # used only by the generic `openai` backend
# KEDU_ALLOW_CLOUD=1         # required to use gemini/openai (cost guard); vllm is local/free

# vllm backend — a local vllm-mlx server (Apple Silicon). Own namespace, so it
# coexists with the lmstudio KEDU_* config above without clobbering it.
# VLLM_MODEL (and VLLM_BRAIN_MODEL) can be EITHER:
#   • a HuggingFace MLX repo id — PORTABLE, vllm-mlx downloads it (use this for shared setups)
#   • an absolute path to a local MLX model dir — this machine only, no re-download,
#     e.g. an LM Studio download at ~/.lmstudio/models/lmstudio-community/<name>-MLX-4bit
# Whatever you put here is also the served model id, so it doubles as the request name.
VLLM_BASE_URL=http://localhost:8000/v1
# Nemotron Omni 4bit MLX. First run: `uv run python scripts/patch-vllm-nemotron-audio.py`
# (fixes mlx_vlm double-transposing the 4bit audio tower — see README "Serving").
VLLM_MODEL=mlx-community/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-4bit
# VLLM_BRAIN_MODEL=mlx-community/...   # brain instance served by scripts/serve-vllm.sh on :8001
# VLLM_API_KEY=none
#
# ── Alternative serving: native vllm-metal (upstream vLLM + Metal plugin; real PagedAttention) ──
# vllm-metal doesn't support Nemotron-Omni's MoE, so this path serves Qwen3-VL-4B (vision) and
# DeepSeek-R1-Distill-Qwen-7B (brain) instead. Start it with scripts/serve-vllm-metal.sh, then set:
#   VLLM_MODEL=qwen3-vl-4b                        # served-model name the client sends (vision :8000)
#   NEMOTRON_BASE_URL=http://localhost:8001/v1
#   NEMOTRON_MODEL=deepseek-r1-distill-qwen-7b    # brain on :8001
# Two instances share one Mac — keep the KV cache small: VLLM_MAX_MODEL_LEN=8192,
# VLLM_METAL_MEM_FRACTION=0.24 (verified no swap thrashing). docs/perf.html has the PagedAttention A/B.

# ── vllm-mlx performance tuning (all optional; defaults preserve prior behavior) ──
# Offline sweep (analyze.py — the curator's per-video keyframe pass):
#   KEDU_CONCURRENCY=4       fan out N frames at once (default 1; only the `vllm` backend
#                            batches them — mlx/lmstudio stay sequential). Auto-downscales to
#                            768px as an OOM guard unless analyze.py --max-px is set.
#   KEDU_MAX_TOKENS=1024     cap spec generation (default 6000; lower for a plain VLM, keep high
#                            for a reasoning-model vision backend)
#   (per-run: analyze.py --max-px 768  downscales each frame's long edge; default 0 = full res)
#   KEDU_TIMEOUT=60          client request timeout in s (drops a stuck frame fast; the client
#                            uses max_retries=0 so a drop never amplifies a pile-up)
# Server (scripts/serve-vllm.sh):
#   VLLM_TIMEOUT=180         server-side runaway cap in s — the hard backstop that frees a zombie
#                            slot, since a client disconnect alone may not cancel generation
#                            (no orphan cancellation). Keep >= the client KEDU_TIMEOUT.
#   VLLM_MAX_NUM_SEQS=8      cap concurrent sequences (unset = vllm-mlx default 256)
#   VLLM_KV_CACHE_QUANT=1    8-bit KV cache to fit more concurrent image sequences

# Agent brain (reasoning). Default: the same vllm-mlx :8000 instance as vision (one model
# serves both). Point at :1234 instead to run the brain on LM Studio.
NEMOTRON_BASE_URL=http://localhost:8000/v1
NEMOTRON_MODEL=mlx-community/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-4bit
# NEMOTRON_API_KEY=lm-studio

# ── Session ──────────────────────────────────────────────────────────────────
AGENT_HANDLE=you

# ── Supabase (global widget cache) ─────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_PASSWORD=<db-password>
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Misc ───────────────────────────────────────────────────────────────────────
# HF_TOKEN=hf_xxx               # HuggingFace token, for gated model downloads
# APIFY_USER_ID=xxx             # YouTube discovery

# Cloud inference via OpenRouter (credit-metered platform key). Users can also BYOK in-app.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-2.5-flash
